# =============================================================================
# INQUIRO Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# -----------------------------------------------------------------------------
# LLM Provider Selection
# -----------------------------------------------------------------------------
# Options: openai, anthropic, ollama, lm_studio, gemini
LLM_PROVIDER=ollama

# Default model for the selected provider
# Examples:
#   - openai: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
#   - anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514
#   - ollama: llama3.1, mistral, codellama, qwen3
#   - lm_studio: local-model
#   - gemini: gemini-2.0-flash, gemini-1.5-pro
LLM_MODEL=gpt-oss-safeguard:20b

# LLM Parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# API Keys (only needed for cloud providers)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
# GOOGLE_API_KEY=your_google_api_key_here
# GROQ_API_KEY=your_groq_key_here


# -----------------------------------------------------------------------------
# Local LLM Settings
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
LM_STUDIO_BASE_URL=http://localhost:1234

# -----------------------------------------------------------------------------
# Run Mode
# -----------------------------------------------------------------------------
# Options: auto, literature, data, full
# auto = LLM analyzes objective and suggests mode, user confirms
# literature = literature search only, skip dataset search/synthetic
# data = data analysis only, skip literature tasks
# full = both agents active (original behavior)
RUN_MODE=auto

# -----------------------------------------------------------------------------
# Seed Papers
# -----------------------------------------------------------------------------
# Path to folder of PDFs to pre-load into RAG before cycle 1
# Leave empty or comment out to disable
SEED_PAPERS_DIR=./seed_papers

# -----------------------------------------------------------------------------
# Database Settings
# -----------------------------------------------------------------------------
DATABASE_PATH=./data/world_model.db

# -----------------------------------------------------------------------------
# Output Settings
# -----------------------------------------------------------------------------
OUTPUT_DIR=./outputs
SAVE_NOTEBOOKS=true

# -----------------------------------------------------------------------------
# Execution Settings
# -----------------------------------------------------------------------------
MAX_CYCLES=20
TASKS_PER_CYCLE=3
MAX_RETRIES=3
EXECUTION_TIMEOUT_SECONDS=300

# -----------------------------------------------------------------------------
# Docker Sandbox Settings
# -----------------------------------------------------------------------------
DOCKER_IMAGE=inquiro-sandbox:latest
DOCKER_MEMORY_LIMIT=4g
DOCKER_CPU_LIMIT=2.0

# -----------------------------------------------------------------------------
# Literature Search Settings
# -----------------------------------------------------------------------------
MAX_PAPERS_PER_SEARCH=20
MAX_PAPERS_TO_READ=15

# Semantic Scholar (optional — increases rate limit from 100 to 1000 req/5min)
# Get a free key at: https://www.semanticscholar.org/product/api#api-key
# SEMANTIC_SCHOLAR_API_KEY=your_key_here

# CORE (optional — 200M+ open access papers with full text)
# Get a free key at: https://core.ac.uk/services/api
# CORE_API_KEY=your_key_here

# Dimensions (optional — 130M+ papers, grants, patents, clinical trials)
# Apply for free access at: https://www.dimensions.ai/scientometric-research/
# Option 1: API key (paid tier)
# DIMENSIONS_API_KEY=your_key_here
# Option 2: Username/password (free scientometric research tier)
# DIMENSIONS_USERNAME=your_username
# DIMENSIONS_PASSWORD=your_password

# -----------------------------------------------------------------------------
# RAG Settings
# -----------------------------------------------------------------------------
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=10

# -----------------------------------------------------------------------------
# Dataset Search
# -----------------------------------------------------------------------------
# HuggingFace token (optional — needed for private/gated datasets)
HF_TOKEN=YOUR_HF_TOKEN

# Kaggle requires ~/.kaggle/kaggle.json — see https://www.kaggle.com/docs/api

# -----------------------------------------------------------------------------
# Model Router (per-task LLM routing)
# -----------------------------------------------------------------------------
# When enabled, different task types use different models/providers.
# When disabled, everything uses LLM_PROVIDER/LLM_MODEL.
ROUTER_ENABLED=true

# Strong model — for orchestration, finding extraction, report writing
ROUTER_STRONG_PROVIDER=gemini
ROUTER_STRONG_MODEL=gemini-2.0-flash

# Fast model — for query generation, paper ranking, scoring
# Note: Groq free tier has a 12K TPM limit which is too small for paper ranking.
# Using Gemini for fast tier too — it handles large prompts fine.
ROUTER_FAST_PROVIDER=gemini
ROUTER_FAST_MODEL=gemini-2.0-flash

# Code model — for Data Agent code generation (88% HumanEval with qwen2.5-coder)
# This runs LOCALLY on your GPU, saving API costs for the code-heavy tasks.
# Requires: ollama pull qwen2.5-coder:7b (4.7GB, fits 8GB VRAM)
ROUTER_CODE_PROVIDER=ollama
ROUTER_CODE_MODEL=qwen2.5-coder:7b

# Local model — fallback / reasoning tasks (uses LLM_PROVIDER/LLM_MODEL if empty)
# Requires: ollama pull qwen3:8b (5.0GB)
ROUTER_LOCAL_PROVIDER=ollama
ROUTER_LOCAL_MODEL=qwen3:8b

# Code tier for Data Agent
ROUTER_CODE_PROVIDER=ollama
ROUTER_CODE_MODEL=qwen2.5-coder:7b

# Update local model
ROUTER_LOCAL_MODEL=qwen3:8b

# CONTACT_EMAIL="enter your email here"

# -----------------------------------------------------------------------------
# Domain-Specific Dataset Sources (optional, for dataset search)
# -----------------------------------------------------------------------------
# These enable specialized dataset search for specific research domains.
# All are free to obtain.

# FRED (Federal Reserve Economic Data) - US economic indicators
# Get key at: https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=your_fred_api_key

# NOAA (Climate Data Online) - Weather and climate data
# Get token at: https://www.ncdc.noaa.gov/cdo-web/token
# NOAA_TOKEN=your_noaa_token

# US Census - Demographic data
# Get key at: https://api.census.gov/data/key_signup.html
# CENSUS_API_KEY=your_census_api_key

# Kaggle - General ML datasets (place kaggle.json in ~/.kaggle/)
# Download from: https://www.kaggle.com/settings → API → Create New Token

# -----------------------------------------------------------------------------
# Automated Peer Review
# -----------------------------------------------------------------------------
# Enable academic-style peer review of generated reports
PEER_REVIEW_ENABLED=true

# Minimum report length (characters) to trigger review
# PEER_REVIEW_MIN_LENGTH=500

# -----------------------------------------------------------------------------
# VLM Figure Verification
# -----------------------------------------------------------------------------
# Enable vision model verification of generated figures
FIGURE_VERIFICATION_ENABLED=true

# Maximum figures to verify per run
# FIGURE_VERIFICATION_MAX_FIGURES=10

# Minimum score (1-4) to pass verification
# FIGURE_VERIFICATION_MIN_SCORE=2.0

# -----------------------------------------------------------------------------
# Reproducibility Package
# -----------------------------------------------------------------------------
# Generate everything needed to reproduce a INQUIRO run
REPRODUCIBILITY_ENABLED=true

# -----------------------------------------------------------------------------
# Domain-Specific Skill Prompts
# -----------------------------------------------------------------------------
# Inject specialized knowledge for research domains (economics, biology, etc.)
DOMAIN_SKILLS_ENABLED=true